vars: {
  d2-config: {
    layout-engine: elk
    # Terminal theme code
    theme-id: 300
  }
}

direction: down

root: agent-auth
root.width: 400

f0: Token Management
f0.width: 400
root -> f0
f0_container: "" {
  grid-columns: 1
  grid-rows: 7
  grid-gap: 5
  style: {
    stroke-width: 0
    fill: transparent
  }
  f1: Create Token Pair
  f1.width: 400
  f2: Refresh Token Pair
  f2.width: 400
  f3: Revoke Token Family
  f3.width: 400
  f4: Modify Token Family Scopes
  f4.width: 400
  f5: Rotate Token Family
  f5.width: 400
  f6: Introspect Token
  f6.width: 400
  f7: Detect Refresh Token Reuse
  f7.width: 400
}
f0 -> f0_container

f8: Token Validation
f8.width: 400
root -> f8
f8_container: "" {
  grid-columns: 1
  grid-rows: 4
  grid-gap: 5
  style: {
    stroke-width: 0
    fill: transparent
  }
  f9: Verify Token Signature
  f9.width: 400
  f10: Check Token Expiry
  f10.width: 400
  f11: Check Scope Authorization
  f11.width: 400
  f12: Resolve Access Tier
  f12.width: 400
}
f8 -> f8_container

