#
# Integration-test image only — bundles keyrings.alt plaintext backend
# so agent-auth starts unattended. Never publish; never use in production.
#
# The same image runs every console-script entry point in
# ``pyproject.toml`` (``agent-auth``, ``things-bridge``, ``things-cli``,
# ``things-client-cli-applescript``); each Compose service overrides
# ``command``/``entrypoint`` to pick which one to run.

FROM python:3.12-slim-bookworm

# ``tests_support`` (always-approve / always-deny notification plugins)
# and ``tests/things_client_fake`` (the fake things-client subprocess
# the bridge invokes during integration tests) are intentionally
# excluded from the ``agent-auth`` wheel so they can never ship to
# production. The package files are copied into the image below;
# pointing PYTHONPATH at ``/opt/tests-support`` lets
# ``importlib.import_module("tests_support.always_*")`` and
# ``python -m tests.things_client_fake`` resolve them without a real
# installed distribution.
ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    PIP_NO_CACHE_DIR=1 \
    HOME=/home/agent-auth \
    XDG_CONFIG_HOME=/home/agent-auth/.config \
    XDG_DATA_HOME=/home/agent-auth/.local/share \
    XDG_STATE_HOME=/home/agent-auth/.local/state \
    PYTHON_KEYRING_BACKEND=keyrings.alt.file.PlaintextKeyring \
    PYTHONPATH=/opt/tests-support

RUN useradd --create-home --uid 1001 --shell /usr/sbin/nologin agent-auth

WORKDIR /src

COPY pyproject.toml README.md ./
COPY src/ ./src/
COPY tests/__init__.py ./tests/__init__.py
COPY tests/things_client_fake/ ./tests/things_client_fake/

RUN pip install --no-cache-dir . "keyrings.alt>=5.0" \
 && mkdir -p /opt/tests-support/tests \
 && cp -r src/tests_support /opt/tests-support/tests_support \
 && cp tests/__init__.py /opt/tests-support/tests/__init__.py \
 && cp -r tests/things_client_fake /opt/tests-support/tests/things_client_fake

RUN mkdir -p "$XDG_CONFIG_HOME/agent-auth" \
             "$XDG_CONFIG_HOME/things-bridge" \
             "$XDG_CONFIG_HOME/things-cli" \
             "$XDG_DATA_HOME/agent-auth" \
             "$XDG_STATE_HOME/agent-auth" \
             "$XDG_STATE_HOME/things-bridge" \
             "$XDG_CONFIG_HOME/python_keyring" \
    && chown -R agent-auth:agent-auth /home/agent-auth

USER agent-auth

EXPOSE 9100 9200

ENTRYPOINT ["agent-auth", "serve"]
