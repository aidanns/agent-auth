{
  "include": [
    "src",
    "tests"
  ],
  "exclude": [
    ".venv",
    ".venv-*",
    "build",
    "dist",
    "**/__pycache__",
    "**/*.egg-info"
  ],
  "typeCheckingMode": "strict",
  "pythonVersion": "3.11",
  "reportMissingTypeStubs": "warning",
  "ignore": [
    "tests",
    "src/tests_support"
  ]
}
